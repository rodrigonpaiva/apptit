{
  "name": "apptit",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --respawn",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.2",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@types/glob": "^8.1.0",
    "glob": "^11.0.2",
    "minimatch": "^10.0.1"
  }
}
