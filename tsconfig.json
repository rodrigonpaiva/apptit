{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "baseUrl": ".",
    "composite": true,
    "paths": {
      "@api/common": ["packages/common/src"],
      "@api/config": ["packages/config/src"],
      "@api/clients": ["packages/clients/src"]
    }
  },
  "include": ["apps/**/*", "packages/**/*"]
}